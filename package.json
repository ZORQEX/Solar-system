{
  "name": "universe-sim-2049",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multithreaded universe simulator: N-body physics, procedural worlds, emergent civilizations.",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "test": "node --test \"backend/tests/**/*.test.ts\"",
    "demo": "node scripts/demo-solar-system.ts",
    "demo:life": "node scripts/demo-life.ts",
    "serve": "node scripts/serve.ts",
    "frontend": "npm --workspace @universe-sim/frontend run dev",
    "build:frontend": "npm --workspace @universe-sim/frontend run build",
    "typecheck": "tsc -p backend/tsconfig.json --noEmit",
    "typecheck:frontend": "npm --workspace @universe-sim/frontend run typecheck"
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/node": "^22.19.21",
    "@types/ws": "^8.18.1",
    "ws": "^8.21.0"
  }
}
